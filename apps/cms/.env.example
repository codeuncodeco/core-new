# A generated secret for Payload (`openssl rand -hex 32`).
PAYLOAD_SECRET=

# Required to hit /seed or /wipe in production (`openssl rand -hex 32`).
# In local dev the secret check is bypassed.
SEED_SECRET=

# Base URL of the public web app. Used by Payload's livePreview feature to
# build the preview iframe URLs per collection.
#   local   : http://localhost:4321
#   staging : https://staging.codeuncode.com   (baked into wrangler.jsonc vars)
#   prod    : https://codeuncode.com           (added in Phase 6)
WEB_URL=http://localhost:4321

# Public URL the CMS is served at. Used as `serverURL` in the Payload config so
# admin URLs in emails (reset password, verify, etc.) render as absolute links.
#   local : http://localhost:3000
#   beta  : https://cms-beta.codeuncode.com   (baked into wrangler.jsonc vars)
CMS_URL=http://localhost:3000

# Resend API key for transactional email (wire up in Phase 4).
# In prod use `wrangler secret put RESEND_API_KEY` rather than committing it.
RESEND_API_KEY=

# Cloudflare deploy hook URL for the web app. When set, Payload POSTs to it on
# content changes to trigger a web rebuild. Leave empty in dev.
WEB_DEPLOY_HOOK_URL=
