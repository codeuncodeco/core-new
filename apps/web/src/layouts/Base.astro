---
import "../styles/global.css";

type Props = {
  title: string;
  description?: string;
  image?: string;
};

const {
  title,
  description = "Web development, design and deployment for people doing serious work. Studio from Bengaluru.",
  image = "/og-image.png",
} = Astro.props;

const siteName = "Code Uncode";
const siteUrl = "https://codeuncode.com";
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL(image, siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#ffc93f" />
    <meta name="theme-color" content="#fdfdfa" />
    <meta name="color-scheme" content="light" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_IN" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..700;1,9..144,400..600&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <script
      src="https://kit.fontawesome.com/5ee19ef111.js"
      crossorigin="anonymous"
      defer></script>
    <script is:inline>
      // Rate-card reveal: if ?ratecard is in the URL, remember it and expose prices site-wide.
      (() => {
        try {
          const url = new URL(window.location.href);
          if (url.searchParams.has("ratecard")) {
            localStorage.setItem("cu-ratecard", "1");
          }
          if (localStorage.getItem("cu-ratecard") === "1") {
            document.documentElement.classList.add("show-rates");
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <div class="mx-auto max-w-5xl px-6 py-10 pb-28 sm:px-10 sm:py-14 sm:pb-14">
      <header
        class="mb-16 flex items-center justify-between border-b border-[var(--color-border)] pb-6"
      >
        <a href="/" class="logo group" aria-label="Code Uncode home">
          <span class="logo__mark" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              width="16"
              height="16"
              fill="none"
              stroke="currentColor"
              stroke-width="2.25"
              stroke-linecap="square"
            >
              <path d="M8 6 L3 12 L8 18"></path>
              <path d="M16 6 L21 12 L16 18"></path>
              <path d="M14 4 L10 20"></path>
            </svg>
          </span>
          <span class="logo__word">
            <span>code</span><span class="logo__slash">/</span><span
              >uncode</span
            >
          </span>
        </a>
        <nav
          class="top-nav hidden gap-6 text-sm uppercase tracking-[0.14em] text-[var(--color-muted)] md:flex"
        >
          <a href="/work" class="hover:text-[var(--color-fg)]">Work</a>
          <a href="/about" class="hover:text-[var(--color-fg)]">About</a>
          <a href="/contact" class="hover:text-[var(--color-fg)]">Contact</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>
    </div>
    {/* BottomNav lands in Phase 5 when contact page arrives. */}
    <style>
      .logo {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        text-decoration: none;
        color: inherit;
      }
      .logo__mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.9rem;
        height: 1.9rem;
        background: var(--color-accent);
        color: var(--color-accent-ink);
        border-radius: 4px;
      }
      .logo__word {
        font-family: var(--font-serif);
        font-size: 1.5rem;
        font-weight: 500;
        letter-spacing: -0.01em;
        line-height: 1;
      }
      .logo__slash {
        color: var(--color-muted);
        margin: 0 0.08em;
        font-style: italic;
      }
      .logo:hover .logo__mark {
        transform: rotate(-6deg);
      }
    </style>
  </body>
</html>
