---
// Full-document layout for a rendered proposal. Used by both the public
// /proposals/<slug> route and the admin preview /preview/proposals/<slug>
// route. Self-contained: Tailwind via CDN, print CSS, no marketing-site
// chrome — just the proposal.
import type { Proposal, Client, Media } from "@cms/payload-types";
import { mediaUrl } from "../lib/cms";

interface Props {
  proposal: Proposal;
  // Timestamp shown in the version label (typically the version's updatedAt
  // for ?v= renders, or the doc's updatedAt for the latest published view).
  renderedAt?: string | null;
  // When true, suppress the version label (e.g. live preview where the
  // doc isn't necessarily saved yet).
  hideVersionLabel?: boolean;
  // When true, emit data-edit-path attributes on editable elements and
  // render numbers as raw values (no ₹ / % formatting inside the editable
  // span) so the in-place editor at /edit/proposals/<slug> can wire them
  // up to contenteditable.
  editMode?: boolean;
}

const {
  proposal,
  renderedAt = null,
  hideVersionLabel = false,
  editMode = false,
} = Astro.props;
// Helper — returns undefined in non-edit mode so Astro omits the attribute.
const ep = (path: string) => (editMode ? path : undefined);

const client = (typeof proposal.client === "object" ? proposal.client : null) as Client | null;
const logoMedia = (client?.logo && typeof client.logo === "object" ? client.logo : null) as Media | null;
const logoUrl = mediaUrl(logoMedia?.url);

const accentColor = proposal.accentColor || "#f97316";
const fontFamily = proposal.fontFamily || "League Spartan";

const formatDate = (iso: string | null | undefined): string => {
  if (!iso) return "";
  return new Date(iso).toLocaleDateString("en-IN", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
};

const formatINR = (amount: number): string =>
  `₹${new Intl.NumberFormat("en-IN", { maximumFractionDigits: 0 }).format(amount)}`;

const versionLabel =
  !hideVersionLabel && renderedAt
    ? new Date(renderedAt).toLocaleString("en-IN", {
        day: "2-digit",
        month: "short",
        year: "numeric",
        hour: "numeric",
        minute: "2-digit",
      })
    : null;

const costItems = proposal.costItems ?? [];
const grandTotal = costItems.reduce((sum, item) => sum + (item?.amount ?? 0), 0);
const showCostSection = costItems.length > 0;
const showRecurring = (proposal.recurringCosts ?? []).length > 0;
const showPaymentTerms = (proposal.paymentTerms ?? []).length > 0;
const showTechStack = (proposal.techStack ?? []).length > 0;
const summaryCards = proposal.summaryCards ?? [];
const scopeItems = proposal.scopeItems ?? [];

const fontImport =
  fontFamily === "League Spartan"
    ? '@import url("https://fonts.googleapis.com/css2?family=League+Spartan:wght@300;400;500;600;700;800;900&display=swap");'
    : "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{proposal.projectName} - Proposal</title>
    <meta name="robots" content="noindex, nofollow" />
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline define:vars={{ accentColor, fontFamily }}>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { sans: [fontFamily, "sans-serif"] },
            colors: { accent: accentColor },
          },
        },
      };
    </script>
    <style is:inline set:html={`
      ${fontImport}
      * { font-family: "${fontFamily}", sans-serif; }
      .tabnum { font-variant-numeric: tabular-nums; }
      @media print {
        @page { margin: 2cm; }
        .container-main { padding: 0 !important; }
        section, table { break-inside: avoid; }
        h2 { break-after: avoid; }
        .page-break { break-before: page; }
      }
    `}></style>
  </head>

  <body class="bg-white text-gray-700 font-sans antialiased text-xl">
    <div class="container-main max-w-4xl mx-auto px-8 py-12">
      <!-- Header -->
      <header class="pb-8 mb-10 border-b-2 border-gray-900">
        {logoUrl ? (
          <img src={logoUrl} alt={client?.name ?? proposal.projectName} class="h-20 mb-6" />
        ) : (
          <h1 class="text-4xl font-semibold mb-6" data-edit-path={ep('projectName')}>
            {proposal.projectName}
          </h1>
        )}
        <p class="text-base uppercase tracking-widest text-gray-900/50 mb-2">Proposal</p>
        {logoUrl && (
          <p class="text-2xl text-gray-900 mb-1" data-edit-path={ep('projectName')}>
            {proposal.projectName}
          </p>
        )}
        {(proposal.subtitle || editMode) && (
          <p class="text-2xl text-gray-900 mb-1" data-edit-path={ep('subtitle')}>
            {proposal.subtitle ?? ''}
          </p>
        )}
        {client?.tagline && (
          <p class="text-xl text-gray-900/70 mb-6">{client.tagline}</p>
        )}
        <div class="flex flex-wrap gap-x-8 gap-y-1 text-base text-gray-900/60">
          <span>
            <span class="text-gray-900/40">Prepared by</span>
            Code Uncode
          </span>
          <span>
            <span class="text-gray-900/40">Date</span>
            {formatDate(proposal.proposalDate)}
          </span>
          {versionLabel && (
            <span>
              <span class="text-gray-900/40">Version</span>
              {versionLabel}
            </span>
          )}
        </div>
      </header>

      <!-- Overview -->
      {(proposal.overview || editMode) && (
        <section class="mb-20">
          <p class="text-xl leading-relaxed" data-edit-path={ep('overview')}>
            {proposal.overview ?? ''}
          </p>
        </section>
      )}

      <!-- At a Glance (summary cards) -->
      {summaryCards.length > 0 && (
        <section class="mb-20">
          <h2 class="font-semibold text-2xl mb-4">At a Glance</h2>
          <div class={`grid grid-cols-1 ${
            summaryCards.length === 1
              ? "sm:grid-cols-1"
              : summaryCards.length === 2
                ? "sm:grid-cols-2"
                : summaryCards.length === 3
                  ? "sm:grid-cols-3"
                  : "sm:grid-cols-2 lg:grid-cols-4"
          } gap-4`}>
            {summaryCards.map((card, i) => (
              <div class="border border-gray-300 rounded-lg p-5">
                <p
                  class="text-base text-gray-400 uppercase tracking-wide mb-1"
                  data-edit-path={ep(`summaryCards.${i}.label`)}
                >
                  {card.label}
                </p>
                <p
                  class="text-3xl font-semibold tabnum"
                  data-edit-path={ep(`summaryCards.${i}.value`)}
                >
                  {card.value}
                </p>
                {(card.caption || editMode) && (
                  <p
                    class="text-base text-gray-600"
                    data-edit-path={ep(`summaryCards.${i}.caption`)}
                  >
                    {card.caption ?? ''}
                  </p>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Scope -->
      {scopeItems.length > 0 && (
        <section class="mb-20">
          <h2 class="font-semibold text-2xl mb-4">Scope</h2>
          <ul class="space-y-3">
            {scopeItems.map((item, i) => (
              <li class="flex items-start gap-3">
                <span class="mt-2 block w-2 h-2 rounded-full bg-accent flex-shrink-0"></span>
                <span>
                  <span class="font-semibold" data-edit-path={ep(`scopeItems.${i}.title`)}>
                    {item.title}
                  </span>
                  {(item.description || editMode) && (
                    <>
                      {' '}- <span data-edit-path={ep(`scopeItems.${i}.description`)}>{item.description ?? ''}</span>
                    </>
                  )}
                </span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- Cost Breakdown -->
      {showCostSection && (
        <section class="mb-20">
          <h2 class="font-semibold text-2xl mb-4" data-edit-path={ep('costSectionLabel')}>
            {proposal.costSectionLabel || 'Cost Breakdown'}
          </h2>
          <table class="w-full text-xl">
            <thead>
              <tr class="border-b border-gray-300">
                <th class="text-left py-3 font-semibold">Item</th>
                <th class="text-left py-3 font-semibold">Cost</th>
              </tr>
            </thead>
            <tbody>
              {costItems.map((item, i) => (
                <tr class="border-b border-gray-200">
                  <td class="py-3" data-edit-path={ep(`costItems.${i}.item`)}>{item.item}</td>
                  <td class="py-3 tabnum">
                    {editMode ? (
                      <>₹<span data-edit-path={`costItems.${i}.amount`} data-edit-type="number">{item.amount ?? 0}</span></>
                    ) : (
                      formatINR(item.amount ?? 0)
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
            <tfoot>
              <tr class="border-t-2 border-gray-900">
                <td class="py-3 font-semibold" data-edit-path={ep('costTotalLabel')}>
                  {proposal.costTotalLabel || 'Total'}
                </td>
                <td class="py-3 font-semibold tabnum">{formatINR(grandTotal)}</td>
              </tr>
            </tfoot>
          </table>
          <p class="text-base text-gray-500 mt-2">+18% GST</p>
        </section>
      )}

      <!-- Technical Architecture -->
      {showTechStack && (
        <section class="mb-20">
          <h2 class="font-semibold text-2xl mb-4">Technical Architecture</h2>
          <table class="w-fit">
            <tbody class="divide-y divide-gray-200">
              {proposal.techStack!.map((row, i) => (
                <tr>
                  <td class="py-2 pr-6 text-gray-400" data-edit-path={ep(`techStack.${i}.label`)}>{row.label}</td>
                  <td class="py-2 font-semibold" data-edit-path={ep(`techStack.${i}.value`)}>{row.value}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      )}

      <!-- Page Break (before recurring costs / payment terms) -->
      {(showRecurring || showPaymentTerms) && <div class="page-break"></div>}

      <!-- Recurring Costs -->
      {showRecurring && (
        <section class="mb-20">
          <h2 class="font-semibold text-2xl mb-4">Recurring Costs</h2>
          <table class="w-full text-xl">
            <thead>
              <tr class="border-b border-gray-300">
                <th class="text-left py-3 font-semibold">Item</th>
                <th class="text-left py-3 font-semibold whitespace-nowrap pr-6">Cost</th>
                <th class="text-left py-3 font-semibold">Notes</th>
              </tr>
            </thead>
            <tbody>
              {proposal.recurringCosts!.map((row, i) => (
                <tr class="border-b border-gray-200">
                  <td class="py-3" data-edit-path={ep(`recurringCosts.${i}.item`)}>{row.item}</td>
                  <td class="py-3 tabnum whitespace-nowrap pr-6" data-edit-path={ep(`recurringCosts.${i}.cost`)}>{row.cost}</td>
                  <td class="py-3 text-gray-600" data-edit-path={ep(`recurringCosts.${i}.notes`)}>{row.notes ?? ''}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      )}

      <!-- Payment Terms -->
      {showPaymentTerms && (
        <section class="mb-20">
          <h2 class="font-semibold text-2xl mb-4">Payment Terms</h2>
          <table class="w-full text-xl">
            <thead>
              <tr class="border-b border-gray-300">
                <th class="text-left py-3 font-semibold">Milestone</th>
                <th class="text-left py-3 font-semibold">Share</th>
                <th class="text-left py-3 font-semibold">Amount</th>
              </tr>
            </thead>
            <tbody>
              {proposal.paymentTerms!.map((row, i) => (
                <tr class="border-b border-gray-200">
                  <td class="py-3" data-edit-path={ep(`paymentTerms.${i}.milestone`)}>{row.milestone}</td>
                  <td class="py-3 tabnum">
                    <span data-edit-path={ep(`paymentTerms.${i}.sharePercent`)} data-edit-type="number">{row.sharePercent}</span>%
                  </td>
                  <td class="py-3 tabnum">{formatINR((row.sharePercent / 100) * grandTotal)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      )}

      <!-- Contact -->
      <section class="pt-8 mt-10 border-t-2 border-gray-900">
        <h2 class="font-semibold text-2xl mb-4">Contact</h2>
        <p class="text-xl"><span class="font-semibold">Code Uncode</span></p>
        <p class="text-xl">
          <a href="mailto:hello@codeuncode.com" class="text-accent underline">hello@codeuncode.com</a>
        </p>
      </section>

      <slot />
    </div>

    {editMode && (
      <script
        type="application/json"
        id="proposal-data"
        is:inline
        set:html={JSON.stringify(proposal)}
      />
    )}
    {editMode && <script>import "../scripts/proposal-editor";</script>}
  </body>
</html>
