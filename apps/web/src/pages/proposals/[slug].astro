---
// Public, print-ready proposal page. Rendered on demand (SSR) so changes in
// the CMS show up immediately without redeploying. Default URL renders the
// latest published version. ?v=<versionId> renders a specific past version.
export const prerender = false;

import { getProposalBySlug, getProposalVersionById, mediaUrl } from "../../lib/cms";
import type { Proposal, Client, Media } from "@cms/payload-types";

const { slug } = Astro.params;
const versionId = Astro.url.searchParams.get("v");

if (!slug) {
  return new Response("Not Found", { status: 404 });
}

let proposal: Proposal | null = null;
let renderedAt: string | null = null;
let isVersion = false;

if (versionId) {
  const v = await getProposalVersionById(versionId);
  // Verify the version belongs to the proposal at this slug — no cross-slug
  // leaks if someone guesses a version id.
  if (!v || v.version?.urlSlug !== slug) {
    return new Response("Not Found", { status: 404 });
  }
  proposal = v.version;
  renderedAt = v.updatedAt;
  isVersion = true;
} else {
  proposal = await getProposalBySlug(slug);
  if (!proposal) {
    return new Response("Not Found", { status: 404 });
  }
  renderedAt = proposal.updatedAt;
}

const client = (typeof proposal.client === "object" ? proposal.client : null) as Client | null;
const logoMedia = (client?.logo && typeof client.logo === "object" ? client.logo : null) as Media | null;
const logoUrl = mediaUrl(logoMedia?.url);

const accentColor = proposal.accentColor || "#f97316";
const fontFamily = proposal.fontFamily || "League Spartan";

const formatDate = (iso: string | null | undefined): string => {
  if (!iso) return "";
  return new Date(iso).toLocaleDateString("en-IN", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
};

const formatINR = (amount: number): string =>
  `₹${new Intl.NumberFormat("en-IN", { maximumFractionDigits: 0 }).format(amount)}`;

const versionLabel = renderedAt
  ? new Date(renderedAt).toLocaleString("en-IN", {
      day: "2-digit",
      month: "short",
      year: "numeric",
      hour: "numeric",
      minute: "2-digit",
    })
  : null;

const costItems = proposal.costItems ?? [];
const grandTotal = costItems.reduce((sum, item) => sum + (item?.amount ?? 0), 0);
const showCostSection = costItems.length > 0;
const showRecurring = (proposal.recurringCosts ?? []).length > 0;
const showPaymentTerms = (proposal.paymentTerms ?? []).length > 0;
const showTechStack = (proposal.techStack ?? []).length > 0;
const summaryCards = proposal.summaryCards ?? [];
const scopeItems = proposal.scopeItems ?? [];

// Drafts shouldn't be public. Payload auto-filters via _status; this is a
// belt-and-braces guard for the version flow where _status lives on the
// version wrapper rather than the doc.
if (!isVersion && (proposal as { _status?: string })._status === "draft") {
  return new Response("Not Found", { status: 404 });
}

const fontImport =
  fontFamily === "League Spartan"
    ? '@import url("https://fonts.googleapis.com/css2?family=League+Spartan:wght@300;400;500;600;700;800;900&display=swap");'
    : "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{proposal.projectName} - Proposal</title>
    <meta name="robots" content="noindex, nofollow" />
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline define:vars={{ accentColor, fontFamily }}>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { sans: [fontFamily, "sans-serif"] },
            colors: { accent: accentColor },
          },
        },
      };
    </script>
    <style is:inline set:html={`
      ${fontImport}
      * { font-family: "${fontFamily}", sans-serif; }
      .tabnum { font-variant-numeric: tabular-nums; }
      @media print {
        @page { margin: 2cm; }
        .container-main { padding: 0 !important; }
        section, table { break-inside: avoid; }
        h2 { break-after: avoid; }
        .page-break { break-before: page; }
      }
    `}></style>
  </head>

  <body class="bg-white text-gray-700 font-sans antialiased text-xl">
    <div class="container-main max-w-4xl mx-auto px-8 py-12">
      <!-- Header -->
      <header class="pb-8 mb-10 border-b-2 border-gray-900">
        {logoUrl ? (
          <img src={logoUrl} alt={client?.name ?? proposal.projectName} class="h-20 mb-6" />
        ) : (
          <h1 class="text-4xl font-semibold mb-6">{proposal.projectName}</h1>
        )}
        <p class="text-base uppercase tracking-widest text-gray-900/50 mb-2">Proposal</p>
        {logoUrl && (
          <p class="text-2xl text-gray-900 mb-1">{proposal.projectName}</p>
        )}
        {proposal.subtitle && (
          <p class="text-2xl text-gray-900 mb-1">{proposal.subtitle}</p>
        )}
        {client?.tagline && (
          <p class="text-xl text-gray-900/70 mb-6">{client.tagline}</p>
        )}
        <div class="flex flex-wrap gap-x-8 gap-y-1 text-base text-gray-900/60">
          <span>
            <span class="text-gray-900/40">Prepared by</span>
            Code Uncode
          </span>
          <span>
            <span class="text-gray-900/40">Date</span>
            {formatDate(proposal.proposalDate)}
          </span>
          {versionLabel && (
            <span>
              <span class="text-gray-900/40">Version</span>
              {versionLabel}
            </span>
          )}
        </div>
      </header>

      <!-- Overview -->
      {proposal.overview && (
        <section class="mb-20">
          <p class="text-xl leading-relaxed">{proposal.overview}</p>
        </section>
      )}

      <!-- At a Glance (summary cards) -->
      {summaryCards.length > 0 && (
        <section class="mb-20">
          <h2 class="font-semibold text-2xl mb-4">At a Glance</h2>
          <div class={`grid grid-cols-1 ${
            summaryCards.length === 1
              ? "sm:grid-cols-1"
              : summaryCards.length === 2
                ? "sm:grid-cols-2"
                : summaryCards.length === 3
                  ? "sm:grid-cols-3"
                  : "sm:grid-cols-2 lg:grid-cols-4"
          } gap-4`}>
            {summaryCards.map((card) => (
              <div class="border border-gray-300 rounded-lg p-5">
                <p class="text-base text-gray-400 uppercase tracking-wide mb-1">{card.label}</p>
                <p class="text-3xl font-semibold tabnum">{card.value}</p>
                {card.caption && (
                  <p class="text-base text-gray-600">{card.caption}</p>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Scope -->
      {scopeItems.length > 0 && (
        <section class="mb-20">
          <h2 class="font-semibold text-2xl mb-4">Scope</h2>
          <ul class="space-y-3">
            {scopeItems.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-2 block w-2 h-2 rounded-full bg-accent flex-shrink-0"></span>
                <span>
                  <span class="font-semibold">{item.title}</span>
                  {item.description && <> - {item.description}</>}
                </span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- Cost Breakdown -->
      {showCostSection && (
        <section class="mb-20">
          <h2 class="font-semibold text-2xl mb-4">{proposal.costSectionLabel || "Cost Breakdown"}</h2>
          <table class="w-full text-xl">
            <thead>
              <tr class="border-b border-gray-300">
                <th class="text-left py-3 font-semibold">Item</th>
                <th class="text-left py-3 font-semibold">Cost</th>
              </tr>
            </thead>
            <tbody>
              {costItems.map((item) => (
                <tr class="border-b border-gray-200">
                  <td class="py-3">{item.item}</td>
                  <td class="py-3 tabnum">{formatINR(item.amount ?? 0)}</td>
                </tr>
              ))}
            </tbody>
            <tfoot>
              <tr class="border-t-2 border-gray-900">
                <td class="py-3 font-semibold">{proposal.costTotalLabel || "Total"}</td>
                <td class="py-3 font-semibold tabnum">{formatINR(grandTotal)}</td>
              </tr>
            </tfoot>
          </table>
          <p class="text-base text-gray-500 mt-2">+18% GST</p>
        </section>
      )}

      <!-- Technical Architecture -->
      {showTechStack && (
        <section class="mb-20">
          <h2 class="font-semibold text-2xl mb-4">Technical Architecture</h2>
          <table class="w-fit">
            <tbody class="divide-y divide-gray-200">
              {proposal.techStack!.map((row) => (
                <tr>
                  <td class="py-2 pr-6 text-gray-400">{row.label}</td>
                  <td class="py-2 font-semibold">{row.value}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      )}

      <!-- Page Break (before recurring costs / payment terms) -->
      {(showRecurring || showPaymentTerms) && <div class="page-break"></div>}

      <!-- Recurring Costs -->
      {showRecurring && (
        <section class="mb-20">
          <h2 class="font-semibold text-2xl mb-4">Recurring Costs</h2>
          <table class="w-full text-xl">
            <thead>
              <tr class="border-b border-gray-300">
                <th class="text-left py-3 font-semibold">Item</th>
                <th class="text-left py-3 font-semibold whitespace-nowrap pr-6">Cost</th>
                <th class="text-left py-3 font-semibold">Notes</th>
              </tr>
            </thead>
            <tbody>
              {proposal.recurringCosts!.map((row) => (
                <tr class="border-b border-gray-200">
                  <td class="py-3">{row.item}</td>
                  <td class="py-3 tabnum whitespace-nowrap pr-6">{row.cost}</td>
                  <td class="py-3 text-gray-600">{row.notes ?? ""}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      )}

      <!-- Payment Terms -->
      {showPaymentTerms && (
        <section class="mb-20">
          <h2 class="font-semibold text-2xl mb-4">Payment Terms</h2>
          <table class="w-full text-xl">
            <thead>
              <tr class="border-b border-gray-300">
                <th class="text-left py-3 font-semibold">Milestone</th>
                <th class="text-left py-3 font-semibold">Share</th>
                <th class="text-left py-3 font-semibold">Amount</th>
              </tr>
            </thead>
            <tbody>
              {proposal.paymentTerms!.map((row) => (
                <tr class="border-b border-gray-200">
                  <td class="py-3">{row.milestone}</td>
                  <td class="py-3 tabnum">{row.sharePercent}%</td>
                  <td class="py-3 tabnum">{formatINR((row.sharePercent / 100) * grandTotal)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      )}

      <!-- Contact -->
      <section class="pt-8 mt-10 border-t-2 border-gray-900">
        <h2 class="font-semibold text-2xl mb-4">Contact</h2>
        <p class="text-xl"><span class="font-semibold">Code Uncode</span></p>
        <p class="text-xl">
          <a href="mailto:hello@codeuncode.com" class="text-accent underline">hello@codeuncode.com</a>
        </p>
      </section>
    </div>
  </body>
</html>
