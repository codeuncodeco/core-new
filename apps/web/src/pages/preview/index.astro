---
// SSR preview variant of / (home) — fetches draft Services so editors can see
// unpublished service edits in the menu before hitting publish.
export const prerender = false;

import Base from "../../layouts/Base.astro";
import ServicesMenu from "../../components/ServicesMenu.astro";
import { getPublishedServicesPreview, getCategories } from "../../lib/cms";
import type { Category, Service } from "@cms/payload-types";

const cookie = Astro.request.headers.get("cookie");
let services = await getPublishedServicesPreview(cookie);

// Payload's Live Preview postMessage sends form state with relationship
// fields as bare IDs (no depth expansion). Rehydrate `category` so downstream
// components can treat it as a populated object like the initial SSR fetch.
const hydrateCategory = async (
  incoming: Partial<Service>,
  existing: Service | undefined,
): Promise<Partial<Service>> => {
  if (typeof incoming.category !== "number") return incoming;
  const prev = existing?.category;
  if (prev && typeof prev === "object" && prev.id === incoming.category) {
    return { ...incoming, category: prev };
  }
  const categories = await getCategories();
  const match = categories.find((c) => c.id === incoming.category);
  return match ? { ...incoming, category: match as Category } : incoming;
};

if (Astro.request.method === "POST") {
  const incoming = (await Astro.request.json()) as
    | (Partial<Service> & { id?: number })
    | null;
  if (incoming?.id) {
    const idx = services.findIndex((s) => s.id === incoming.id);
    const hydrated = await hydrateCategory(incoming, services[idx]);
    if (idx >= 0) {
      services = services.slice();
      services[idx] = { ...services[idx], ...(hydrated as Service) };
    } else {
      services = [...services, hydrated as Service];
    }
  }
}

Astro.response.headers.set("X-Robots-Tag", "noindex, nofollow");
Astro.response.headers.set(
  "Content-Security-Policy",
  "frame-ancestors 'self' https://cms.codeuncode.com https://test-cms.codeuncode.com http://localhost:3000",
);
---

<Base title="Home (preview) — Code Uncode">
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <section class="mb-16">
    <h1
      class="mt-5 text-4xl md:text-5xl leading-[1.25] tracking-tight sm:text-6xl"
    >
      We design, build and maintain <span class="hero-mark"
        >modern websites</span
      > for people doing serious work
    </h1>
    <p class="mt-8 max-w-2xl text-base text-[var(--color-muted)]">
      Fast, durably designed systems for people who think in years
    </p>
  </section>

  <ServicesMenu services={services} />
</Base>

<style>
  .hero-mark {
    font-family: var(--font-serif);
    font-style: italic;
    background: linear-gradient(
      180deg,
      transparent 62%,
      var(--color-accent) 62%,
      var(--color-accent) 94%,
      transparent 94%
    );
    padding: 0 0.08em;
  }
</style>

<script>
  import "../../scripts/live-preview";
</script>
