---
// SSR preview variant of /about — fetches draft Partners and Brands (via
// cookie-forwarded auth) so editors can see unpublished changes before
// hitting publish. On POST (from the live-preview client script), the
// request body contains the single doc the editor is currently editing;
// we merge it into the fetched list by id so the iframe reflects typing
// in real time without waiting for a save.
export const prerender = false;

import Base from "../../layouts/Base.astro";
import Partners from "../../components/Partners.astro";
import Clients from "../../components/Clients.astro";
import { getBrandsPreview, getPartnersPreview } from "../../lib/cms";
import type { Brand, Partner } from "@cms/payload-types";

const cookie = Astro.request.headers.get("cookie");
const collection = Astro.url.searchParams.get("collection");

let [partners, brands] = await Promise.all([
  getPartnersPreview(cookie),
  getBrandsPreview(cookie),
]);

// POST = live-preview event. Body is the edited doc. Use the ?collection=
// query param (set by the admin's livePreview.url) to know which list to
// merge into.
if (Astro.request.method === "POST") {
  const incoming = (await Astro.request.json()) as
    | (Partial<Partner> & { id?: number })
    | (Partial<Brand> & { id?: number });
  if (collection === "partners" && incoming && "tagline" in incoming) {
    partners = mergeDoc(partners, incoming as Partner);
  } else if (collection === "brands" && incoming && "domain" in incoming) {
    brands = mergeDoc(brands, incoming as Brand);
  }
}

function mergeDoc<T extends { id: number }>(list: T[], incoming: T): T[] {
  if (!incoming?.id) return list;
  const idx = list.findIndex((d) => d.id === incoming.id);
  if (idx === -1) return [...list, incoming];
  const next = list.slice();
  next[idx] = { ...list[idx], ...incoming };
  return next;
}

const hasBrands = brands.length > 0;

// Don't let search engines index preview pages.
Astro.response.headers.set("X-Robots-Tag", "noindex, nofollow");
// Allow the Payload admin (same parent domain in prod; localhost:3000 in dev)
// to embed this page as an iframe for the live-preview panel. Locks out
// everyone else.
Astro.response.headers.set(
  "Content-Security-Policy",
  "frame-ancestors 'self' https://cms.codeuncode.com https://test-cms.codeuncode.com http://localhost:3000",
);

const team = [
  {
    name: "Shreshth Mohan",
    role: "Technology",
    image:
      "https://codeuncode.com/cdn-cgi/image/format=webp,width=400/https://cdn.codeuncode.com/media/shreshth-mohan.jpg",
  },
  {
    name: "Aparna Divakar",
    role: "Design",
    image:
      "https://codeuncode.com/cdn-cgi/image/format=webp,width=400/https://cdn.codeuncode.com/media/aparna.e7b28324.png",
  },
  {
    name: "Amit",
    role: "Product & UX",
    image:
      "https://codeuncode.com/cdn-cgi/image/format=webp,width=400/https://cdn.codeuncode.com/media/amit.753a67f2.png",
  },
];
---

<Base title="About (preview) — Code Uncode">
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <section class="hero">
    <p class="eyebrow">Hallo from Bengaluru</p>
    <h1>
      Three people, <span class="hero-mark">one studio</span>
    </h1>
    <p class="lead">
      We're a small studio that designs and builds for people doing serious work
      - and we like long projects, longer conversations, and attention to detail
      for creating sustainable systems.
    </p>
  </section>

  <section class="team">
    <p class="section-eyebrow">Team</p>
    <ul class="team__grid">
      {
        team.map((m) => (
          <li class="member">
            <figure class="member__photo">
              <img src={m.image} alt={m.name} loading="lazy" />
            </figure>
            <div class="member__info">
              <p class="member__name">{m.name}</p>
              <p class="member__role">{m.role}</p>
            </div>
          </li>
        ))
      }
      <li class="member member--cta">
        <a href="/contact?service=collaborating+with+you" class="collab">
          <span class="collab__box">
            <span class="collab__icon" aria-hidden="true">
              <i class="fa-slab fa-regular fa-face-smile"></i>
            </span>
            <span class="collab__title">Want to collaborate?</span>
          </span>
          <span class="collab__sub">Come say hello →</span>
        </a>
      </li>
    </ul>
  </section>

  <section class="how">
    <p class="section-eyebrow">How we work</p>
    <ul class="how__list">
      <li>
        <strong>Small by design.</strong> The people you meet are the people doing
        the work.
      </li>
      <li>
        <strong>Patient with the brief.</strong> We'll ask three more questions than
        build the wrong thing.
      </li>
      <li>
        <strong>Built to last.</strong> Sites we shipped years ago still load fast
        and still get edited.
      </li>
      <li>
        <strong>Honest about pricing.</strong> Technology is expensive, we want to
        help you make the best choices.
      </li>
    </ul>
  </section>

  <Partners partners={partners} />

  {hasBrands && <Clients brands={brands} />}

  <section class="cta">
    <h2>Have something to build?</h2>
    <p>Five quick questions and we'll write back.</p>
    <a href="/contact" class="cta__btn">Start a project →</a>
  </section>
</Base>

<script>
  import "../../scripts/live-preview";
</script>

<style>
  /* Styles identical to /about — kept separate here so preview is self-contained
     and its rendering won't drift even if public about.astro is restyled mid-edit.
     Source of truth: apps/web/src/pages/about.astro. */
