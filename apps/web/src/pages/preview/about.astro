    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-dim);
    margin: 0 0 1rem;
  }
  .team {
    max-width: 60rem;
    margin: 0 auto 5rem;
  }
  .team__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.25rem;
  }
  @media (max-width: 720px) {
    .team__grid {
