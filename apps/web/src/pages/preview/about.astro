    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-dim);
    margin: 0 0 0.75rem;
  }
  .hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 3.75rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 500;
    margin: 0;
  }
  .hero-mark {
    font-style: italic;
    background: linear-gradient(
      180deg,
      transparent 62%,
      var(--color-accent) 62%,
      var(--color-accent) 94%,
      transparent 94%
    );
    padding: 0 0.08em;
  }
  .lead {
    margin: 1.25rem 0 0;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.6;
  }
