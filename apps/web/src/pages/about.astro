---
import Base from "../layouts/Base.astro";
import Partners from "../components/Partners.astro";

const team = [
  {
    name: "Shreshth Mohan",
    role: "Technology",
    image:
      "https://codeuncode.com/cdn-cgi/image/format=webp,width=400/https://cdn.codeuncode.com/media/shreshth-mohan.jpg",
  },
  {
    name: "Aparna Divakar",
    role: "Design",
    image:
      "https://codeuncode.com/cdn-cgi/image/format=webp,width=400/https://cdn.codeuncode.com/media/aparna.e7b28324.png",
  },
  {
    name: "Amit",
    role: "Product & UX",
    image:
      "https://codeuncode.com/cdn-cgi/image/format=webp,width=400/https://cdn.codeuncode.com/media/amit.753a67f2.png",
  },
];
---

<Base title="About — Code Uncode">
  <section class="hero">
    <p class="eyebrow">Hallo from Bengaluru</p>
    <h1>
      Three people, <span class="hero-mark">one studio</span>
    </h1>
    <p class="lead">
      We're a small studio that designs and builds for people doing serious work
      - and we like long projects, longer conversations, and attention to detail
      for creating sustainable systems.
    </p>
  </section>

  <section class="team">
    <p class="section-eyebrow">Team</p>
    <ul class="team__grid">
      {
        team.map((m) => (
          <li class="member">
            <figure class="member__photo">
              <img src={m.image} alt={m.name} loading="lazy" />
            </figure>
            <div class="member__info">
              <p class="member__name">{m.name}</p>
              <p class="member__role">{m.role}</p>
            </div>
          </li>
        ))
      }
      <li class="member member--cta">
        <a href="/contact?service=collaborating+with+you" class="collab">
          <span class="collab__box">
            <span class="collab__icon" aria-hidden="true">
              <i class="fa-slab fa-regular fa-face-smile"></i>
            </span>
            <span class="collab__title">Want to collaborate?</span>
          </span>
          <span class="collab__sub">Come say hello →</span>
        </a>
      </li>
    </ul>
  </section>

  <section class="how">
    <p class="section-eyebrow">How we work</p>
    <ul class="how__list">
      <li>
        <strong>Small by design.</strong> The people you meet are the people doing
        the work.
      </li>
      <li>
        <strong>Patient with the brief.</strong> We'll ask three more questions than
        build the wrong thing.
      </li>
      <li>
        <strong>Built to last.</strong> Sites we shipped years ago still load fast
        and still get edited.
      </li>
      <li>
        <strong>Honest about pricing.</strong> Technology is expensive, we want to
        help you make the best choices.
      </li>
    </ul>
  </section>

  <Partners />

  {/* Clients section lands in Phase 4 (Brands collection). */}

  <section class="cta">
    <h2>Have something to build?</h2>
    <p>Five quick questions and we'll write back.</p>
    <a href="/contact" class="cta__btn">Start a project →</a>
  </section>

  <style>
    .hero {
      max-width: 42rem;
      margin: 0 auto 4rem;
    }
    .eyebrow {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-dim);
      margin: 0 0 0.75rem;
    }
    .hero h1 {
      font-family: var(--font-serif);
      font-size: clamp(2.5rem, 6vw, 3.75rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
      font-weight: 500;
      margin: 0;
    }
    .hero-mark {
      font-style: italic;
      background: linear-gradient(
        180deg,
        transparent 62%,
        var(--color-accent) 62%,
        var(--color-accent) 94%,
        transparent 94%
      );
      padding: 0 0.08em;
    }
    .lead {
      margin: 1.25rem 0 0;
      color: var(--color-muted);
      font-size: 1.05rem;
      line-height: 1.6;
    }

    .section-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-dim);
      margin: 0 0 1rem;
    }

    .team {
      max-width: 60rem;
      margin: 0 auto 5rem;
    }
    .team__grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1.25rem;
    }
    @media (max-width: 720px) {
      .team__grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
      }
    }
    .member {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
    }
    .member__photo {
      margin: 0;
      aspect-ratio: 1 / 1;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      overflow: hidden;
      transition:
        transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
        border-color 220ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .member:hover .member__photo {
      transform: translateY(-2px);
      border-color: var(--color-accent);
    }
    .member__photo img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .member__info {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }
    .member__name {
      font-family: var(--font-serif);
      font-size: 1.25rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      margin: 0;
    }
    .member__role {
      margin: 0;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-muted);
    }

    /* Collab CTA — mirrors member layout (box on top, label underneath). */
    .collab {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
      text-decoration: none;
      color: inherit;
    }
    .collab__box {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      aspect-ratio: 1 / 1;
      padding: 1rem;
      border: 1px dashed var(--color-border);
      border-radius: 12px;
      background: var(--color-surface);
      justify-content: space-between;
      transition:
        transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
        border-color 220ms cubic-bezier(0.22, 1, 0.36, 1),
        background-color 220ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .collab:hover .collab__box {
      transform: translateY(-2px);
      border-color: var(--color-accent);
      border-style: solid;
    }
    .collab__icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border-radius: 999px;
      background: var(--color-accent);
      color: var(--color-accent-ink);
      font-size: 20px;
    }
    .collab__title {
      font-family: var(--font-serif);
      font-size: 1.25rem;
      font-weight: 500;
      line-height: 1.2;
      letter-spacing: -0.01em;
    }
    .collab__sub {
      margin: 0;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-muted);
    }
    .collab:hover .collab__sub {
      color: var(--color-fg);
    }

    .how {
      max-width: 42rem;
      margin: 0 auto 5rem;
    }
    .how__list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .how__list li {
      padding-left: 1.25rem;
      position: relative;
      color: var(--color-muted);
      line-height: 1.55;
    }
    .how__list li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0.65em;
      width: 0.5rem;
      height: 0.5rem;
      background: var(--color-accent);
      border-radius: 999px;
    }
    .how__list strong {
      color: var(--color-fg);
      font-weight: 500;
    }

    .cta {
      max-width: 42rem;
      margin: 0 auto;
      padding: 2rem 1.5rem;
      border: 1px solid var(--color-border);
      border-radius: 12px;
      background: var(--color-surface);
      text-align: center;
    }
    .cta h2 {
      font-family: var(--font-serif);
      font-size: 1.75rem;
      font-weight: 500;
      margin: 0 0 0.4rem;
    }
    .cta p {
      margin: 0 0 1.25rem;
      color: var(--color-muted);
    }
    .cta__btn {
      display: inline-block;
      background: var(--color-accent);
      color: var(--color-accent-ink);
      padding: 0.75rem 1.25rem;
      text-decoration: none;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      letter-spacing: 0.04em;
      border-radius: 6px;
    }
    .cta__btn:hover {
      filter: brightness(0.95);
    }
  </style>
</Base>
