---
// In-place editor for a proposal. Renders ProposalLayout with edit
// affordances; the proposal-editor client script wires every
// [data-edit-path] element to contenteditable + debounced save.
//
// Auth: in production we forward the editor's CMS auth cookie to
// /api/users/me to verify a logged-in admin. In local dev (or when the
// CMS is unreachable) we let the page render anyway — saves will still
// fail at the CMS layer if the cookie isn't valid, so this just avoids
// a hard 401 during development.
export const prerender = false;

import { getProposalBySlugPreview } from "../../../lib/cms";
import ProposalLayout from "../../../layouts/ProposalLayout.astro";

const { slug } = Astro.params;
if (!slug) return new Response("Not Found", { status: 404 });

const cookie = Astro.request.headers.get("cookie");
const CMS_URL = import.meta.env.PUBLIC_CMS_URL || "http://localhost:3000";

// Auth check — production only; non-fatal in dev.
let authed = false;
let unreachable = false;
let meStatus: number | null = null;
let cookieHasPayloadToken = false;
let meBodyPreview = "";
try {
  cookieHasPayloadToken = Boolean(cookie && /(?:^|;\s*)payload-token=/.test(cookie));
  const meRes = await fetch(`${CMS_URL}/api/users/me`, {
    headers: cookie ? { cookie } : {},
  });
  meStatus = meRes.status;
  const text = await meRes.text();
  meBodyPreview = text.length > 400 ? `${text.slice(0, 400)}…` : text;
  if (meRes.ok) {
    try {
      const me = JSON.parse(text) as { user?: { id?: number | string } };
      authed = Boolean(me.user?.id);
    } catch {
      // not JSON
    }
  }
} catch {
  unreachable = true;
}

if (!authed && !import.meta.env.DEV && !unreachable) {
  // Diagnostic body so we can tell *why* it failed without sifting through
  // worker logs.
  const tokens = cookie?.match(/(?:^|;\s*)payload-token=([^;]+)/g) ?? [];
  const lines = [
    "Unauthorized — couldn't verify a CMS session for this request.",
    "",
    `Cookie header present:    ${cookie ? "yes" : "no"}`,
    `payload-token in cookies: ${cookieHasPayloadToken ? "yes" : "no"}`,
    `payload-token count:      ${tokens.length}`,
    `/api/users/me status:     ${meStatus ?? "no response"}`,
    `/api/users/me body:       ${meBodyPreview || "(empty)"}`,
    `CMS reachable:            ${unreachable ? "no" : "yes"}`,
    "",
    "Common causes:",
    "  - /me returns user:null → JWT couldn't be validated.",
    "    Check PAYLOAD_SECRET matches the secret the JWT was signed with.",
    "  - More than one payload-token cookie in the header → another",
    "    subdomain (cms.*, cms-test.*) set a token at a different domain",
    "    scope. The browser sends both; Payload picks the wrong one.",
    "    Clear cookies for ALL *.codeuncode.com subdomains and re-login.",
  ].join("\n");
  return new Response(lines, {
    status: 401,
    headers: { "content-type": "text/plain; charset=utf-8" },
  });
}

const proposal = await getProposalBySlugPreview(slug, cookie);
if (!proposal) return new Response("Not Found", { status: 404 });

Astro.response.headers.set("X-Robots-Tag", "noindex, nofollow");
---

<ProposalLayout proposal={proposal} editMode={true} hideVersionLabel={true} />
