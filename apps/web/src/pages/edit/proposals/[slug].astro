---
// In-place editor for a proposal. Renders ProposalLayout with edit
// affordances; the proposal-editor client script wires every
// [data-edit-path] element to contenteditable + debounced save.
//
// Auth: in production we forward the editor's CMS auth cookie to
// /api/users/me to verify a logged-in admin. In local dev (or when the
// CMS is unreachable) we let the page render anyway — saves will still
// fail at the CMS layer if the cookie isn't valid, so this just avoids
// a hard 401 during development.
export const prerender = false;

import { getProposalBySlugPreview } from "../../../lib/cms";
import ProposalLayout from "../../../layouts/ProposalLayout.astro";

const { slug } = Astro.params;
if (!slug) return new Response("Not Found", { status: 404 });

const cookie = Astro.request.headers.get("cookie");
const CMS_URL = import.meta.env.PUBLIC_CMS_URL || "http://localhost:3000";

// Auth check — production only; non-fatal in dev.
let authed = false;
let unreachable = false;
let meStatus: number | null = null;
let cookieHasPayloadToken = false;
let meBodyPreview = "";
let tokenFingerprint = "";
let cookieLength = 0;
let altMeStatus: number | null = null;
let altMeBodyPreview = "";

// Pull just the payload-token=<jwt> portion so we can fingerprint it (head
// and tail of the JWT) without exposing the whole signed value.
const tokenMatch = cookie?.match(/(?:^|;\s*)payload-token=([^;]+)/);
const tokenValue = tokenMatch?.[1] ?? "";
if (tokenValue) {
  const head = tokenValue.slice(0, 8);
  const tail = tokenValue.slice(-8);
  tokenFingerprint = `${head}…${tail} (len ${tokenValue.length})`;
}
cookieLength = cookie?.length ?? 0;

try {
  cookieHasPayloadToken = Boolean(tokenValue);

  // Primary call — forward the entire incoming cookie header verbatim.
  const meRes = await fetch(`${CMS_URL}/api/users/me`, {
    headers: cookie ? { cookie } : {},
  });
  meStatus = meRes.status;
  const text = await meRes.text();
  meBodyPreview = text.length > 400 ? `${text.slice(0, 400)}…` : text;
  if (meRes.ok) {
    try {
      const me = JSON.parse(text) as { user?: { id?: number | string } };
      authed = Boolean(me.user?.id);
    } catch {
      // not JSON
    }
  }

  // Diagnostic alt-call — send ONLY payload-token, no other cookies. If this
  // succeeds where the primary fails, something else in the cookie header is
  // confusing Payload's parser.
  if (!authed && tokenValue) {
    const altRes = await fetch(`${CMS_URL}/api/users/me`, {
      headers: {
        cookie: `payload-token=${tokenValue}`,
        // Mimic a normal browser request a bit — server-to-server fetch
        // sometimes lacks a User-Agent which can be filtered upstream.
        "user-agent": "Mozilla/5.0 (proposal-edit-ssr)",
      },
    });
    altMeStatus = altRes.status;
    const altText = await altRes.text();
    altMeBodyPreview = altText.length > 400 ? `${altText.slice(0, 400)}…` : altText;
    if (altRes.ok) {
      try {
        const me = JSON.parse(altText) as { user?: { id?: number | string } };
        if (me.user?.id) {
          authed = true;
        }
      } catch {
        // not JSON
      }
    }
  }
} catch {
  unreachable = true;
}

if (!authed && !import.meta.env.DEV && !unreachable) {
  // Diagnostic body so we can tell *why* it failed without sifting through
  // worker logs.
  const tokens = cookie?.match(/(?:^|;\s*)payload-token=([^;]+)/g) ?? [];
  const lines = [
    "Unauthorized — couldn't verify a CMS session for this request.",
    "",
    `Cookie header present:     ${cookie ? "yes" : "no"}`,
    `Cookie header length:      ${cookieLength}`,
    `payload-token in cookies:  ${cookieHasPayloadToken ? "yes" : "no"}`,
    `payload-token count:       ${tokens.length}`,
    `payload-token fingerprint: ${tokenFingerprint || "(none)"}`,
    `/api/users/me status:      ${meStatus ?? "no response"}`,
    `/api/users/me body:        ${meBodyPreview || "(empty)"}`,
    `Alt /me (only token + UA): ${altMeStatus ?? "skipped"}`,
    `Alt /me body:              ${altMeBodyPreview || "(empty)"}`,
    `CMS reachable:             ${unreachable ? "no" : "yes"}`,
    "",
    "Compare the fingerprint above with the cookie value in DevTools at",
    "cms-dev.codeuncode.com. If they match, the cookie is reaching the CMS",
    "intact and the failure is on the validation side (secret mismatch or",
    "JWT expired). If they DON'T match, the cookie is being mangled in",
    "transit between web → cms.",
    "",
    "If the alt /me call succeeded where the primary failed, an extra",
    "cookie or missing User-Agent on the primary call was confusing the",
    "CMS — let me know the result.",
  ].join("\n");
  return new Response(lines, {
    status: 401,
    headers: { "content-type": "text/plain; charset=utf-8" },
  });
}

const proposal = await getProposalBySlugPreview(slug, cookie);
if (!proposal) return new Response("Not Found", { status: 404 });

Astro.response.headers.set("X-Robots-Tag", "noindex, nofollow");
---

<ProposalLayout proposal={proposal} editMode={true} hideVersionLabel={true} />
