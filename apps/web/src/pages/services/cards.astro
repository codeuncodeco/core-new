---
import Base from "../../layouts/Base.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import ViewSwitcher from "../../components/ViewSwitcher.astro";
import {
  getPublishedServices,
  getRateCardSettings,
  resolveRef,
} from "../../lib/cms";
import type { Category } from "@cms/payload-types";

const [services, settings] = await Promise.all([
  getPublishedServices(),
  getRateCardSettings(),
]);

const currency = settings.currency ?? "INR";
const taxNote = settings.taxNote ?? "Plus GST";

const groups = new Map<string, typeof services>();
for (const svc of services) {
  const cat = resolveRef<Category>(svc.category);
  const key = cat.title;
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(svc);
}
const groupEntries = Array.from(groups.entries()).sort(([a], [b]) =>
  a.localeCompare(b),
);
---

<Base
  title="Services & Rate Card - Code Uncode"
  description="Our services and rates."
>
  <section class="mb-12">
    <p class="text-base uppercase tracking-[0.2em] text-[var(--color-muted)]">
      Rate Card
    </p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl">
      Services & rates
    </h1>
    <p class="mt-4 max-w-2xl text-xl text-[var(--color-muted)]">
      Everything we offer, with transparent pricing. All prices are
      <span class="text-[var(--color-fg)]">{taxNote}</span>.
    </p>
  </section>

  <ViewSwitcher current="cards" />

  {
    groupEntries.map(([tag, items]) => (
      <section class="mb-16">
        <h2 class="mb-6 text-xl uppercase tracking-[0.2em] text-[var(--color-muted)]">
          {tag}
        </h2>
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          {items.map((service) => (
            <ServiceCard service={service} currency={currency} />
          ))}
        </div>
      </section>
    ))
  }

  {
    settings.footerDisclaimer && (
      <p class="mt-16 border-t border-[var(--color-border)] pt-6 text-base italic text-[var(--color-dim)]">
        {settings.footerDisclaimer}
      </p>
    )
  }
</Base>
