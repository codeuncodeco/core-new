---
import Base from "../../layouts/Base.astro";
import PriceTable from "../../components/PriceTable.astro";
import { getPublishedServices, getRateCardSettings } from "../../lib/cms";

export async function getStaticPaths() {
  const services = await getPublishedServices();
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const settings = await getRateCardSettings();
const currency = settings.currency ?? "INR";
const taxNote = settings.taxNote ?? "Plus GST";
---

<Base
  title={`${service.title} - Code Uncode`}
  description={service.summary ?? undefined}
>
  <article>
    <a
      href="/services"
      class="text-base text-[var(--color-muted)] hover:text-[var(--color-fg)]"
    >
      ← All services
    </a>

    <header class="mt-6 mb-10 border-b border-[var(--color-border)] pb-8">
      <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">
        {service.title}
      </h1>
      {
        service.summary && (
          <p class="mt-4 max-w-2xl text-xl text-[var(--color-muted)]">
            {service.summary}
          </p>
        )
      }
      {
        service.tags && service.tags.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {service.tags.map((tag) => (
              <span class="rounded-full border border-[var(--color-border)] px-2.5 py-0.5 text-xs uppercase tracking-wide text-[var(--color-muted)]">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </header>

    <section class="mb-12">
      <h2
        class="mb-4 text-xl uppercase tracking-[0.2em] text-[var(--color-muted)]"
      >
        Pricing
      </h2>
      <div
        class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6"
      >
        <PriceTable prices={service.prices} currency={currency} />
      </div>
      <p class="mt-3 text-sm text-[var(--color-dim)]">{taxNote}</p>
    </section>

    {
      service.inclusions && service.inclusions.length > 0 && (
        <section class="mb-12">
          <h2 class="mb-4 text-xl uppercase tracking-[0.2em] text-[var(--color-muted)]">
            What's included
          </h2>
          <ul class="space-y-2 text-xl">
            {service.inclusions.map((inc) => (
              <li class="flex items-start gap-3">
                <span class="mt-2 h-2 w-2 flex-shrink-0 rounded-full bg-[var(--color-accent)]" />
                <span>{inc.item}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      service.exclusions && service.exclusions.length > 0 && (
        <section class="mb-12">
          <h2 class="mb-4 text-xl uppercase tracking-[0.2em] text-[var(--color-muted)]">
            Not included
          </h2>
          <ul class="space-y-2 text-xl text-[var(--color-muted)]">
            {service.exclusions.map((exc) => (
              <li class="flex items-start gap-3">
                <span class="mt-2 h-2 w-2 flex-shrink-0 rounded-full bg-[var(--color-dim)]" />
                <span>{exc.item}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section
      class="mt-16 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-8"
    >
      <h2 class="text-2xl font-semibold tracking-tight">Interested?</h2>
      <p class="mt-2 text-[var(--color-muted)]">
        Reach out and we'll put together a proposal tailored to your project.
      </p>
      <a
        href="/contact"
        class="mt-5 inline-block rounded-md bg-[var(--color-accent)] px-5 py-3 text-base font-semibold text-black hover:opacity-90"
      >
        Get in touch
      </a>
    </section>
  </article>
</Base>
