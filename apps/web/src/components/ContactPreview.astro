---
// A live "what we'll actually receive" preview. Populated by script hooks in
// ContactWizard.astro — look for updatePreview().
---

<aside class="preview" data-contact-preview aria-live="polite">
  <header class="preview__head">
    <p class="preview__eyebrow">Live preview</p>
  </header>

  <div class="preview__envelope">
    <dl class="preview__meta">
      <dt>To</dt>
      <dd>hello@codeuncode.com</dd>
      <dt>From</dt>
      <dd data-preview="from">
        <span class="preview__empty">your name &lt;you@example.com&gt;</span>
      </dd>
      <dt>Subject</dt>
      <dd data-preview="subject">
        <span class="preview__empty">Brief incoming…</span>
      </dd>
    </dl>

    <div class="preview__divider"></div>

    <dl class="preview__body">
      <div class="preview__row">
        <dt>Looking for</dt>
        <dd data-preview="help">
          <span class="preview__empty">Nothing picked yet</span>
        </dd>
      </div>
      <div class="preview__row">
        <dt data-preview="branch-label">Details</dt>
        <dd data-preview="branch-value">
          <span class="preview__empty">—</span>
        </dd>
      </div>
      <div class="preview__row">
        <dt>Timeline</dt>
        <dd data-preview="timeline"><span class="preview__empty">—</span></dd>
      </div>
      <div class="preview__row">
        <dt>Budget</dt>
        <dd data-preview="budget"><span class="preview__empty">—</span></dd>
      </div>
    </dl>

    <div class="preview__msg">
      <p class="preview__label">Project note</p>
      <p data-preview="message" class="preview__text">
        <span class="preview__empty"
          >Your project description shows up here as you type.</span
        >
      </p>
    </div>
  </div>

  <footer class="preview__foot">
    <span class="preview__stamp" aria-hidden="true">
      <i class="fa-slab fa-regular fa-paper-plane"></i>
    </span>
    <span>We reply within two working days.</span>
  </footer>
</aside>

<style>
  .preview {
    position: sticky;
    top: 1.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-height: calc(100vh - 3rem);
    overflow: auto;
  }

  .preview__head {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .preview__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-dim);
    margin: 0;
  }
  .preview__subtitle {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1rem;
    font-style: italic;
    color: var(--color-muted);
  }

  .preview__envelope {
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    border-radius: 8px;
    padding: 1rem 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.55;
  }

  .preview__meta,
  .preview__body {
    margin: 0;
  }

  .preview__meta {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: 0.3rem 0.85rem;
  }
  .preview__meta dt {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-dim);
    padding-top: 0.15rem;
  }
  .preview__meta dd {
    margin: 0;
    overflow-wrap: anywhere;
  }

  .preview__divider {
    border-top: 1px dashed var(--color-border);
    margin: 0.8rem 0;
  }

  .preview__body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .preview__row {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: 0.3rem 0.85rem;
    align-items: baseline;
  }
  .preview__row dt {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-dim);
  }
  .preview__row dd {
    margin: 0;
    overflow-wrap: anywhere;
  }

  .preview__msg {
    margin-top: 0.9rem;
    border-top: 1px dashed var(--color-border);
    padding-top: 0.8rem;
  }
  .preview__label {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-dim);
    margin: 0 0 0.3rem;
  }
  .preview__text {
    margin: 0;
    white-space: pre-wrap;
    min-height: 3rem;
  }

  /* Unfilled slots: washed-out, italic — easy to skim past. */
  [data-preview] {
    color: var(--color-dim);
    opacity: 0.6;
  }
  .preview__empty {
    color: var(--color-dim);
    font-style: italic;
    font-weight: 400;
  }

  /* Filled slots: full contrast, upright, readable. */
  [data-preview].is-filled {
    color: var(--color-fg);
    opacity: 1;
    font-style: normal;
    font-weight: 500;
  }
  [data-preview].is-filled .preview__empty {
    display: none;
  }

  /* Tiny acknowledgment pulse when a slot becomes filled. */
  [data-preview].just-filled {
    animation: preview-pulse 600ms cubic-bezier(0.22, 1, 0.36, 1);
    border-radius: 3px;
  }
  @keyframes preview-pulse {
    0%   { background-color: color-mix(in srgb, var(--color-accent) 60%, transparent); }
    100% { background-color: transparent; }
  }
  @media (prefers-reduced-motion: reduce) {
    [data-preview].just-filled { animation: none; }
  }

  .preview__foot {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
    letter-spacing: 0.05em;
  }
  .preview__stamp {
    display: inline-flex;
    width: 26px;
    height: 26px;
    align-items: center;
    justify-content: center;
    background: var(--color-accent);
    color: var(--color-accent-ink);
    border-radius: 4px;
    font-size: 12px;
    transform: rotate(-4deg);
  }

  @media (max-width: 899px) {
    .preview {
      position: sticky;
      top: 0.5rem;
      max-height: 55vh;
      padding: 0.85rem 1rem;
      gap: 0.65rem;
      font-size: 0.85rem;
    }
    .preview__head {
      gap: 0.1rem;
    }
    .preview__subtitle {
      font-size: 0.85rem;
    }
    .preview__envelope {
      padding: 0.75rem 0.85rem;
      font-size: 0.8rem;
    }
    .preview__meta,
    .preview__row {
      grid-template-columns: 4rem 1fr;
      gap: 0.2rem 0.65rem;
    }
    .preview__divider {
      margin: 0.55rem 0;
    }
    .preview__msg {
      margin-top: 0.6rem;
      padding-top: 0.55rem;
    }
    .preview__foot {
      display: none;
    }
  }
</style>
