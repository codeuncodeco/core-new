---
import { getBrands, mediaUrl } from "../lib/cms";
import type { Brand } from "@cms/payload-types";

// Brand logos live in the Payload Media collection — upload via the CMS admin
// (Brands collection → image). SVG is recommended so logos stay crisp.
// While nothing is seeded, render wireframe-style placeholders so the section
// still shows up in layout reviews.
// Optional `brands` prop lets callers (e.g. SSR preview routes) inject their
// own list; default behavior fetches published brands.
type Props = { brands?: Brand[] };
const { brands: injected } = Astro.props as Props;
const brands = injected ?? (await getBrands());

type ResolvedBrand = {
  id: number;
  name: string;
  domain: string;
  logoUrl: string;
  alt: string;
};

const resolved: ResolvedBrand[] = brands
  .map((brand): ResolvedBrand | null => {
    const image = typeof brand.image === "object" ? brand.image : null;
    const logoUrl = mediaUrl(image?.url);
    if (!logoUrl) return null;
    return {
      id: brand.id,
      name: brand.name,
      domain: brand.domain,
      logoUrl,
      alt: image?.alt ?? `${brand.name} logo`,
    };
  })
  .filter((b): b is ResolvedBrand => b !== null);

const showPlaceholder = resolved.length === 0;
const placeholderSlots = Array.from({ length: 6 }, (_, i) =>
  String(i + 1).padStart(2, "0"),
);
---

<section class="clients">
  <p class="clients__eyebrow">Clients</p>
  <p class="clients__blurb">Teams we've shipped work with.</p>

  {
    showPlaceholder ? (
      <ul class="clients__grid clients__grid--placeholder" aria-hidden="true">
        {placeholderSlots.map((n) => (
          <li>
            <span class="client client--placeholder">Logo {n}</span>
          </li>
        ))}
      </ul>
    ) : (
      <ul class="clients__grid">
        {resolved.map((brand) => (
          <li>
            <a
              class="client"
              href={`https://${brand.domain}`}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={brand.name}
            >
              <img
                src={brand.logoUrl}
                alt={brand.alt}
                loading="lazy"
                decoding="async"
              />
            </a>
          </li>
        ))}
      </ul>
    )
  }
</section>

<style>
  .clients {
    max-width: 60rem;
    margin: 0 auto 5rem;
  }
  .clients__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-dim);
    margin: 0 0 0.5rem;
  }
  .clients__blurb {
    color: var(--color-muted);
    margin: 0 0 1.25rem;
    font-size: 0.95rem;
    max-width: 32rem;
  }

  .clients__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem 2.5rem;
  }
  .clients__grid li {
    display: flex;
  }

  .client {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    color: var(--color-muted);
    filter: grayscale(1);
    opacity: 0.75;
    transition:
      filter 220ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 220ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .client:hover {
    filter: grayscale(0);
    opacity: 1;
    transform: translateY(-1px);
  }
  .client img {
    max-height: 100%;
    max-width: 160px;
    width: auto;
    height: auto;
    display: block;
  }

  /* Wireframe placeholder — removed once real brand logos land in Payload. */
  .clients__grid--placeholder {
    gap: 1rem 1.25rem;
  }
  .client--placeholder {
    height: 48px;
    min-width: 120px;
    padding: 0 1rem;
    border: 1px dashed var(--color-border);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-dim);
    filter: none;
    opacity: 1;
    cursor: default;
  }
  .client--placeholder:hover {
    transform: none;
  }

  @media (max-width: 640px) {
    .clients {
      margin-bottom: 4rem;
    }
    .clients__blurb {
      font-size: 0.9rem;
    }
    .clients__grid {
      gap: 1.25rem 1.75rem;
    }
    .clients__grid--placeholder {
      gap: 0.75rem 0.85rem;
    }
    .client {
      height: 36px;
    }
    .client img {
      max-width: 120px;
    }
    .client--placeholder {
      height: 36px;
      min-width: 96px;
      padding: 0 0.75rem;
      font-size: 0.62rem;
    }
  }
</style>
