---
import ServiceIcon from "./ServiceIcon.astro";
import {
  getPublishedServices,
  getRateCardSettings,
  getCategories,
  resolveRef,
} from "../lib/cms";
import type { Category, Service, Tag } from "@cms/payload-types";
import type { IconName } from "@cms/shared/icons";
import { formatAmount } from "../lib/format";

// Optional `services` prop lets callers (e.g. SSR preview routes) inject
// their own list (e.g. drafts). Default behavior fetches published services.
type Props = { services?: Service[] };
const { services: injectedServices } = Astro.props as Props;

const [servicesFetched, settings, categories] = await Promise.all([
  injectedServices ? Promise.resolve(null) : getPublishedServices(),
  getRateCardSettings(),
  getCategories(),
]);
const services = injectedServices ?? servicesFetched!;

const currency = settings.currency ?? "INR";
const taxNote = settings.taxNote ?? "Plus GST";

type Row = {
  service: (typeof services)[number];
  category: Category;
  icon: IconName;
  tags: Tag[];
  from: { amount: number; suffix?: string } | null;
};

const isOnlyRow = (label?: string | null) => !!label && /\bonly\b/i.test(label);

const startingAt = (
  prices: (typeof services)[number]["prices"],
): Row["from"] => {
  const rows = (prices ?? []).filter((p) => !isOnlyRow(p.label));
  if (rows.length === 0) return null;
  const min = rows.reduce(
    (best, r) => (r.amount < best.amount ? r : best),
    rows[0],
  );
  return { amount: min.amount, suffix: min.suffix ?? undefined };
};

const rows: Row[] = services.map((service) => {
  const category = resolveRef<Category>(service.category);
  const icon = (service.icon ?? category.icon) as IconName;
  const tags = (service.tags ?? []).map((t) => resolveRef<Tag>(t));
  return { service, category, icon, tags, from: startingAt(service.prices) };
});

const grouped = new Map<string, Row[]>();
for (const cat of categories) grouped.set(cat.slug, []);
for (const row of rows) {
  const bucket = grouped.get(row.category.slug);
  if (!bucket) {
    throw new Error(
      `Service "${row.service.slug}" has category "${row.category.slug}" not present in categories collection.`,
    );
  }
  bucket.push(row);
}

for (const list of grouped.values()) {
  list.sort((a, b) => {
    const af = a.service.flagship ? 0 : 1;
    const bf = b.service.flagship ? 0 : 1;
    if (af !== bf) return af - bf;
    return (a.service.displayOrder ?? 0) - (b.service.displayOrder ?? 0);
  });
}
---

<div class="services">
  {
    categories.map((category) => {
      const list = grouped.get(category.slug) ?? [];
      return (
        <section class="course">
          <header class="course__head">
            <h2 class="course__title">{category.title}</h2>
            {category.blurb && <p class="course__blurb">{category.blurb}</p>}
          </header>

          {list.length > 0 ? (
            <ul class="flags stagger">
              {list.map(({ service, category: cat, icon, from }) => {
                const params = new URLSearchParams({
                  category: cat.slug,
                  service: service.title,
                  slug: service.slug,
                });
                return (
                  <li>
                    <a class="flag" href={`/contact?${params.toString()}`}>
                      <span class="flag__icon" aria-hidden="true">
                        <ServiceIcon name={icon} size={22} />
                      </span>
                      <span class="flag__body">
                        <span class="flag__title">{service.title}</span>
                        {service.summary && (
                          <span class="flag__summary">{service.summary}</span>
                        )}
                      </span>
                      {from && (
                        <span class="flag__price tabnum">
                          <span class="flag__from">from</span>{" "}
                          {formatAmount(from.amount, currency)}
                          {from.suffix && (
                            <span class="flag__suffix"> {from.suffix}</span>
                          )}
                        </span>
                      )}
                    </a>
                  </li>
                );
              })}
            </ul>
          ) : (
            <div class="empty">
              <p>Cooking this up. Want to be the first customer?</p>
              <a href="/contact" class="empty__cta">
                Tell us what you need →
              </a>
            </div>
          )}
        </section>
      );
    })
  }

  <p class="footnote">{taxNote} · tailored to scope.</p>
</div>

<style>
  .services {
    max-width: 60rem;
    margin: 0 auto;
  }
  .course {
    margin-top: 3rem;
  }
  .course:first-of-type {
    margin-top: 0;
  }
  .course__head {
    margin-bottom: 1.25rem;
  }
  .course__title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0 0 0.4rem;
  }
  .course__blurb {
    color: var(--color-muted);
    margin: 0;
    font-size: 0.95rem;
    max-width: 32rem;
  }

  .flags {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .flag {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    text-align: left;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.1rem 1.2rem;
    color: inherit;
    text-decoration: none;
  }
  .flag:hover {
    border-color: var(--color-fg);
    transform: translateY(-1px);
  }
  .flag__icon {
    flex-shrink: 0;
    display: inline-flex;
    width: 46px;
    height: 46px;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    background: transparent;
    border-radius: 999px;
    transition:
      background-color 220ms cubic-bezier(0.22, 1, 0.36, 1),
      color 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .flag:hover .flag__icon {
    background: var(--color-accent);
    color: var(--color-accent-ink);
  }
  .flag__body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
    min-width: 0;
  }
  .flag__title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .flag__summary {
    color: var(--color-muted);
    font-size: 0.9rem;
  }
  .flag__price {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-fg);
    white-space: nowrap;
    flex-shrink: 0;
    display: none;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    margin-left: auto;
  }
  :global(html.show-rates) .flag__price {
    display: flex;
  }
  .flag__from {
    font-size: 0.62rem;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-dim);
  }
  .flag__suffix {
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--color-dim);
  }

  .empty {
    border: 1px dashed var(--color-border);
    border-radius: 10px;
    padding: 1.25rem;
    text-align: center;
    color: var(--color-muted);
  }
  .empty p {
    margin: 0 0 0.5rem;
  }
  .empty__cta {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-fg);
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-decoration-thickness: 3px;
    text-underline-offset: 5px;
  }

  .footnote {
    margin-top: 2.5rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-dim);
  }

  @media (max-width: 640px) {
    .course {
      margin-top: 2.25rem;
    }
    .course__title {
      font-size: 1.5rem;
    }
    .course__blurb {
      font-size: 0.9rem;
    }
    .flag {
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 0.85rem;
      padding: 0.9rem 1rem;
      border-radius: 12px;
    }
    .flag__icon {
      width: 36px;
      height: 36px;
      font-size: 16px;
    }
    .flag__title {
      font-size: 1.05rem;
      line-height: 1.25;
    }
    .flag__summary {
      font-size: 0.82rem;
      line-height: 1.4;
    }
    /* Force the price onto its own row on the right so it never fights
       the summary for space. Parent is flex-wrap, so flex-basis 100% does it. */
    .flag__price {
      flex-basis: 100%;
      width: 100%;
      flex-direction: row;
      align-items: baseline;
      justify-content: flex-end;
      gap: 0.4rem;
      margin-left: 0;
      padding-top: 0.2rem;
      border-top: 1px dashed var(--color-border);
      font-size: 0.85rem;
    }
    .flag__from {
      font-size: 0.55rem;
      letter-spacing: 0.14em;
    }
    .flag__from {
      font-size: 0.55rem;
      letter-spacing: 0.14em;
    }
    .flag__suffix {
      font-size: 0.6rem;
    }
  }
</style>
