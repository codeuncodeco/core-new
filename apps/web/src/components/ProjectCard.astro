---
import type { Project } from "@cms/payload-types";
import { getProjectFallback } from "../lib/projectFallbacks";
import { mediaUrl } from "../lib/cms";

type Props = {
  project: Project;
};

const { project } = Astro.props;
const linkable = Boolean(project.url);
const Tag = linkable ? "a" : "div";
const linkProps = linkable
  ? {
      href: project.url,
      target: "_blank",
      rel: "noopener noreferrer",
    }
  : {};

const cmsCover =
  project.cover && typeof project.cover === "object" ? project.cover : null;
const resolvedCover = mediaUrl(cmsCover?.url) ?? getProjectFallback(project.slug);
const coverAlt = cmsCover?.alt ?? `${project.title} preview`;
---

<Tag {...linkProps} class={`card ${linkable ? "card--link" : ""}`}>
  {
    resolvedCover && (
      <figure class="card__cover">
        <img src={resolvedCover} alt={coverAlt} loading="lazy" />
      </figure>
    )
  }

  <div class="card__top mt-3">
    <div class="card__titles">
      <h3 class="card__title">
        {project.title}
        {
          linkable && (
            <span class="card__arrow" aria-hidden="true">
              ↗
            </span>
          )
        }
      </h3>
    </div>
    {project.featured && <span class="card__pill">Featured</span>}
  </div>

  {project.summary && <p class="card__summary">{project.summary}</p>}

  {
    project.tags && project.tags.length > 0 && (
      <ul class="card__tags">
        {project.tags.slice(0, 4).map((tag) => (
          <li>{tag}</li>
        ))}
      </ul>
    )
  }
</Tag>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: inherit;
    text-decoration: none;
    border-radius: 8px;
    overflow: hidden;
  }
  .card--link:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 6px 0 -2px var(--color-accent);
  }
  .card--link:hover .card__arrow {
    transform: translate(2px, -2px);
  }
  .card__cover {
    margin: -1.25rem -1.25rem 0;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .card__top {
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    align-items: flex-start;
  }
  .card__client {
    margin: 0 0 0.25rem;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .card__title {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.2;
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
  }
  .card__arrow {
    display: inline-block;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.9em;
  }
  .card__pill {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    background: var(--color-accent);
    color: var(--color-accent-ink);
    border-radius: 999px;
  }
  .card__summary {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.95rem;
  }
  .card__tags {
    list-style: none;
    padding: 0;
    margin: auto 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding-top: 0.75rem;
  }
  .card__tags li {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.15rem 0.55rem;
  }

  @media (max-width: 640px) {
    .card {
      padding: 0;
      gap: 0;
      border-radius: 14px;
    }
    .card__cover {
      margin: 0;
      aspect-ratio: 4 / 3;
      border-bottom: 1px solid var(--color-border);
      border-top-left-radius: 14px;
      border-top-right-radius: 14px;
    }
    .card__top {
      padding: 0.9rem 1rem 0;
      margin-top: 0;
    }
    .card__title {
      font-size: 1.15rem;
    }
    .card__summary {
      padding: 0.3rem 1rem 0;
      font-size: 0.85rem;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .card__tags {
      padding: 0.6rem 1rem 0.9rem;
      margin: 0;
    }
    .card__tags li {
      font-size: 0.62rem;
      padding: 0.12rem 0.45rem;
    }
    .card--link:hover {
      transform: none;
      box-shadow: none;
    }
    .card--link:active {
      transform: scale(0.99);
    }
  }
</style>
