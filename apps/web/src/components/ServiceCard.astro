---
import type { Service } from '@cms/payload-types'
import PriceSummary from './PriceSummary.astro'

type Props = {
  service: Service
  currency?: string
}

const { service, currency } = Astro.props
---

<a
  href={`/services/${service.slug}`}
  class="block rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6 transition-colors hover:border-[var(--color-accent)]"
>
  <div class="mb-4 flex items-start justify-between gap-4">
    <div>
      <h3 class="text-2xl font-semibold tracking-tight">{service.title}</h3>
      {service.summary && (
        <p class="mt-1 text-base text-[var(--color-muted)]">{service.summary}</p>
      )}
    </div>
  </div>

  <div class="flex flex-col gap-2">
    <PriceSummary prices={service.prices} currency={currency} />
  </div>

  {service.tags && service.tags.length > 0 && (
    <div class="mt-5 flex flex-wrap gap-2">
      {service.tags.map((tag) => (
        <span class="rounded-full border border-[var(--color-border)] px-2.5 py-0.5 text-xs uppercase tracking-wide text-[var(--color-muted)]">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
