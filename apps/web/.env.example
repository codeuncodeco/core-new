# Base URL of the Payload CMS. Used at build time (published content fetches)
# and at runtime inside SSR /preview routes (draft fetches with cookie
# forwarding). Must be PUBLIC_ prefixed so Astro exposes it to the browser
# bundle (live-preview script needs it for origin matching).
#   local   : http://localhost:3000
#   staging : https://cms-staging.codeuncode.com
#   prod    : https://cms.codeuncode.com (Phase 6)
PUBLIC_CMS_URL=http://localhost:3000
