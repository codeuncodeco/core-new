# Base URL of the Payload CMS. Used at build time (published content fetches)
# and at runtime inside SSR /preview routes (draft fetches with cookie
# forwarding). Must be PUBLIC_ prefixed so Astro exposes it to the browser
# bundle (live-preview script needs it for origin matching).
#   local   : http://localhost:3000
#   staging : https://cms-staging.codeuncode.com
#   prod    : https://cms.codeuncode.com (Phase 6)
PUBLIC_CMS_URL=http://localhost:3000

# --- Local dev only: in-place editor (/edit/proposals/<slug>) ---
# localhost:4321 and localhost:3000 don't share cookies, so the WYSIWYG
# editor's save endpoint can't forward an authenticated session from the
# browser. As a dev-mode-only fallback, the save endpoint logs into the CMS
# with these credentials and uses that session for PATCH requests. Use any
# real Payload user — edits will be attributed to that user.
#
# Production never falls back; cookie sharing works there because Payload's
# auth cookie is domain-scoped to .codeuncode.com.
# PAYLOAD_DEV_EMAIL=you@codeuncode.com
# PAYLOAD_DEV_PASSWORD=

# Origin sent on the dev-mode PATCH so Payload's CSRF check (csrf: [WEB_URL])
# accepts the request. Defaults to http://localhost:4321 — only set this if
# you run Astro on a non-default port.
# PUBLIC_WEB_URL=http://localhost:4321
